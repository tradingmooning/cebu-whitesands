# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env.local (dev) or .env.production (prod)
# Never commit files with real values to version control
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
VITE_API_URL=https://your-backend.onrender.com

# Project identity — must match PROJECT_ID / PROJECT_NAME in backend .env
VITE_PROJECT_ID=cebu-whitesand-resort
VITE_APP_NAME=Cebu Whitesand Resort

# Primary public domain (used for canonical URLs, OG tags, etc.)
VITE_DOMAIN=cebu-whitesand-resort.com
