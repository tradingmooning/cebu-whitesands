# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in the values
# Never commit the real .env file to version control
# ─────────────────────────────────────────────────────────────────────────────

PORT=5001
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbName>?appName=<appName>
NODE_ENV=development
LOG_LEVEL=http

JWT_SECRET=<generate-with: openssl rand -hex 64>
JWT_REFRESH_SECRET=<generate-with: openssl rand -hex 64>
JWT_EXPIRES_IN=1d

ADMIN_EMAIL=reservations@cebu-whitesand-resort.com
RESORT_PHONE=
RESORT_WHATSAPP=
RESORT_EMAIL=reservations@cebu-whitesand-resort.com
FACEBOOK_PAGE_URL=

# ─── Cloudflare R2 (primary file storage) ────────────────────────────────────
#
# Step-by-step setup instructions: see R2_SETUP.md
#
# 1. R2_ACCOUNT_ID
#    Where to find: Cloudflare Dashboard → click your account in the top-right
#    dropdown → "Account ID" appears in the right sidebar on the Overview page.
#
# 2. R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY
#    Where to find: Cloudflare Dashboard → R2 (left menu) → "Manage R2 API Tokens"
#    → "Create API Token". Choose "Object Read & Write" permission scoped to
#    your bucket. Copy the Access Key ID and Secret Access Key immediately
#    (the secret is shown only once).
#
# 3. R2_BUCKET_NAME
#    The exact name of the bucket you created in the R2 dashboard.
#
# 4. R2_ENDPOINT
#    Format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#    Replace <ACCOUNT_ID> with your actual Cloudflare account ID.
#
# 5. R2_PUBLIC_URL  (optional)
#    If you connect a custom domain or Cloudflare Worker in front of the bucket,
#    set this to that base URL (e.g. https://cdn.example.com).
#    Leave blank to fall back to R2_ENDPOINT.
#
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_URL=

# ─── Email service ────────────────────────────────────────────────────────────
EMAIL_SERVICE_URL=https://your-email-service.vercel.app/api/send
EMAIL_SERVICE_API_KEY=<your-email-service-api-key>

CLIENT_URL=https://cebu-whitesand-resort.com,http://localhost:5173

# ─── Project identity (used in email subjects & admin UI) ────────────────────────────
PROJECT_ID=cebu-whitesand-resort
PROJECT_NAME=Cebu Whitesand Resort
PROJECT_TAGLINE=Where Crystal Waters Meet White Sands
DOMAIN=cebu-whitesand-resort.com
