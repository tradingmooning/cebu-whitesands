# Zoho SMTP credentials
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
PROJECT_ID=<your-project-id>
SMTP_USER=reservations@example.com
SMTP_PASS=<your-smtp-app-password>

# Sender display name override (optional)
# EMAIL_FROM="Your Resort Name" <reservations@example.com>

# Shared secret — must match EMAIL_SERVICE_API_KEY in backend .env
EMAIL_API_KEY=<generate-a-strong-random-secret>

# Resort contact info (used in email footer)
RESORT_PHONE=+1 000 000 0000
RESORt_EMAIL=reservations@example.com
FACEBOOK_PAGE_URL=https://www.facebook.com/yourpage

# Admin email (receives new booking + payment alert notifications)
ADMIN_EMAIL=reservations@example.com

# Frontend URL (for payment links in emails)
CLIENT_URL=https://www.example.com

# Backend API URL — used to fetch live social links (phone, Facebook) managed by admin
BACKEND_URL=https://your-backend.onrender.com
